# Node modules
node_modules/
**/node_modules/

# Rust build output
target/

# Generated TS (unsec → gen from index.ts / projc.ts)
gen/

# TypeScript output
out/
dist/
build/

# Log files
*.log

# OS files
.DS_Store
Thumbs.db

# Environment files
.env
.env.local
.env.*.local

# VSCode settings
!.vscode/settings.json   # if you want to keep workspace settings

# Compiled JS from TS (if you keep .ts files and don't commit JS)
**/*.d.ts

# Package lock (optional, usually committed for deterministic installs)
# package-lock.json

# Security / secret files
*.key
*.pem
*.p12

# Misc
*.tmp
*.bak
*.swp
