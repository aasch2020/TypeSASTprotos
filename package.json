  "version": "1.0.0",
  "description": "",
  "main": "dist/extension.cjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aasch2020/TypeSASTprotos.git"
  },
  "keywords": [],
  "author": "",
